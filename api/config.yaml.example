sentinel:
  database_url: "sqlite:///sentinel.db"
  # database_url: "postgresql://user:pass@localhost:5432/sentinel"
  host: "0.0.0.0"
  port: 8400
  log_level: "INFO"
  log_file: "/var/log/sentinel/api.log"

auth:
  # Tokens listed here are seeded into the database on `init-db`.
  # For production, use `manage.py create-token` instead and leave this empty.
  tokens: []
  # tokens:
  #   - name: "admin"
  #     token: "sk-admin-xxxxxxxxxxxx"
  #   - name: "prod-web-01"
  #     token: "sk-agent-xxxxxxxxxxxx"

# ──────────────────────────────────────────────────
# Notifications
# ──────────────────────────────────────────────────
# Enable ONE email provider: smtp OR sendgrid. If both are enabled,
# SendGrid takes priority. Leave both disabled to skip email notifications.

notifications:

  # --- SMTP / Gmail ---
  smtp:
    enabled: false
    host: "smtp.gmail.com"
    port: 587
    use_tls: true
    username: ""               # SMTP login (often your email address)
    password: ""               # SMTP password or app-specific password
    from_address: ""           # e.g. "sentinel@example.com"
    from_name: "CXL Sentinel"

  # --- SendGrid ---
  sendgrid:
    enabled: false
    api_key: ""                # SendGrid API key (starts with SG.)
    from_address: ""           # Verified sender in SendGrid
    from_name: "CXL Sentinel"

  # --- Branding ---
  # Customize the look of notification emails.
  branding:
    logo_url: ""               # URL to your logo image (max height ~32px)
    accent_color: "#2563eb"    # Body: stat numbers + latest-commit callout border
    header_theme: "dark"       # "dark" = light text on banner; "light" = dark text on banner
    header_background: ""      # Banner strip color (#cdcdcd, etc.); empty = same as accent_color
    company_name: ""           # Shown next to logo
    footer_text: ""            # Extra text in the email footer

  # --- Delivery behavior ---
  # use_bcc: true puts recipients in BCC (prevents reply-all group chains).
  # to_address: visible in the To: header when use_bcc is true.
  #             Defaults to from_address if blank.
  use_bcc: true
  to_address: ""                # e.g. "notifications@example.com"

  # --- Notification Rules ---
  # Each rule maps a server_id (or "*" wildcard) to recipients with a digest schedule.
  # `send_schedule` controls how often digest emails are sent (10m, 6h, 1d, 7d).
  # Digests are anchored at midnight UTC (e.g. 6h = 00:00, 06:00, 12:00, 18:00 UTC).
  # Commits starting with [NOTIFY] bypass the digest and send immediately.
  rules: []

  # Example rules:
  # rules:
  #   # Notify ops team on all production deploys, digest every 6 hours
  #   - server_id: "*"
  #     server_alias: ""
  #     environments: ["production"]
  #     send_schedule: "6h"
  #     recipients:
  #       - "ops@example.com"
  #       - "lead@example.com"
  #
  #   # Per-server rule: staging + production, digest daily
  #   - server_id: "acme-web"
  #     server_alias: "Acme Web"
  #     environments: ["production", "staging"]
  #     send_schedule: "1d"
  #     recipients:
  #       - "team@example.com"
  #
  #   # Staging-only alerts, every 10 minutes
  #   - server_id: "*"
  #     environments: ["staging"]
  #     send_schedule: "10m"
  #     recipients:
  #       - "dev-team@example.com"
